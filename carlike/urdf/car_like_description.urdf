  </link>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.18157 -0.0028273 0.071028" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_link" />
  </joint>

  <link name="camera_link">
    <inertial>
      <origin xyz="-0.00709799991400401 -5.55111512312578E-17 0" rpy="0 0 0" />
      <mass value="0.0432770796326795" />
      <inertia ixx="0.000109422781743848" ixy="5.14330125635068E-21" ixz="-6.7762635780344E-21" iyy="2.20822840510756E-06" iyz="9.52633907078873E-21" izz="0.000108655714342604" />
