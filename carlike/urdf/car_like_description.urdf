  </link>
  <joint name="camera_joint" type="fixed">
    <origin xyz="0.315 -0.0028273 0.003528" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="camera_link" />
  </joint>

  <link name="arm_link1">
    <inertial>
      <origin xyz="0.040774716875621 -0.00755049354351917 0.0481515680266213" rpy="0 0 0" />
      <mass value="0.0403539816339745" />
      <inertia ixx="5.81781236422276E-05" ixy="5.43915905495608E-08" ixz="-4.22063809027212E-05" iyy="0.000102105539034016" iyz="5.2260499474059E-08" izz="4.40956916787048E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://carlike/meshes/arm_link1.STL" /></geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><box size="0.05 0.05 0.05" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint1" type="revolute">
    <origin xyz="0.059988 -0.012827 0.071886" rpy="0 0 3.1416" />
    <parent link="base_link" />
    <child link="arm_link1" />
    <axis xyz="0 1 0" />
    <limit lower="-1.5" upper="0.87" effort="15" velocity="1.5" />
  </joint>

  <link name="arm_link2">
    <inertial>
      <origin xyz="0.0464180212158517 -0.00755748115764754 -0.0301340675582253" rpy="0 0 0" />
      <mass value="0.0291575348019794" />
      <inertia ixx="2.23524234159972E-05" ixy="5.68977420785463E-08" ixz="2.61179524075733E-05" iyy="6.83038421166921E-05" iyz="-3.23395943661976E-08" izz="4.60730493321112E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://carlike/meshes/arm_link2.STL" /></geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><box size="0.05 0.05 0.05" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint2" type="revolute">
    <origin xyz="0.084015 -0.005104 0.099199" rpy="0 0 0" />
    <parent link="arm_link1" />
    <child link="arm_link2" />
    <axis xyz="0 1 0" />
    <limit lower="-1.57" upper="0.62" effort="15" velocity="1.5" />
  </joint>

  <link name="end_effector_link">
    <inertial>
      <origin xyz="0.00567933304777019 0.000323230704913718 -0.00114626471771576" rpy="0 0 0" />
      <mass value="0.00887280293926091" />
      <inertia ixx="4.30992784457751E-06" ixy="5.541915367406E-08" ixz="-3.78537520897982E-08" iyy="4.22899268083545E-06" iyz="-1.11598581251398E-08" izz="4.12995744920137E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://carlike/meshes/end_effector_link.STL" /></geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><box size="0.05 0.05 0.05" /></geometry>
    </collision>
  </link>
  <joint name="end_effector_joint" type="fixed">
    <origin xyz="0.12668 -0.0094069 -0.074338" rpy="0 0 0" />
    <parent link="arm_link2" />
    <child link="end_effector_link" />
  </joint>

 
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="arm_joint1">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="arm_joint2">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="rear_left_wheel_joint">
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="rear_right_wheel_joint">
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="front_left_wheel_joint">
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="front_right_wheel_joint">
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="left_steering_joint">
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="right_steering_joint">
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
  </ros2_control>

 
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10.0</update_rate>
      <topic>/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <visualize>true</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="camera_sensor" type="camera">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <topic>/camera/image_raw</topic>
      <gz_frame_id>camera_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find carlike)/config/joint_controllers.yaml</parameters>
    </plugin>

    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <publish_nested_models>true</publish_nested_models>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>left_steering_joint</joint_name>
      <joint_name>right_steering_joint</joint_name>
      <joint_name>arm_joint1</joint_name>
      <joint_name>arm_joint2</joint_name>
    </plugin>

    <plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <left_steering_joint>left_steering_joint</left_steering_joint>
      <right_steering_joint>right_steering_joint</right_steering_joint>
      <wheel_base>0.245</wheel_base>
      <wheel_separation>0.305</wheel_separation>
      <kingpin_width>0.170</kingpin_width>
      <wheel_radius>0.05</wheel_radius>
      <steering_limit>0.5</steering_limit>
      <steer_p_gain>10.0</steer_p_gain>
      <steer_i_gain>0.0</steer_i_gain>
      <steer_d_gain>0.5</steer_d_gain>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>


  <gazebo reference="rear_left_wheel_link"><mu1>1.0</mu1><mu2>1.0</mu2><minDepth>0.001</minDepth></gazebo>
  <gazebo reference="rear_right_wheel_link"><mu1>1.0</mu1><mu2>1.0</mu2><minDepth>0.001</minDepth></gazebo>
  <gazebo reference="front_left_wheel_link"><mu1>1.0</mu1><mu2>1.0</mu2><minDepth>0.001</minDepth></gazebo>
  <gazebo reference="front_right_wheel_link"><mu1>1.0</mu1><mu2>1.0</mu2><minDepth>0.001</minDepth></gazebo>

</robot>